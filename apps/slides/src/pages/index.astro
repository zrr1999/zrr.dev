---
import Layout from "../layouts/Layout.astro";
import SlideList from "../components/SlideList.tsx";

import { existsSync } from "node:fs";
import { readdir } from "node:fs/promises";
import { join } from "node:path";

let slides: string[] = [];
const hostingSlides = join(process.cwd(), "..", "..", "hosting", "slides");
const publicSlides = join(process.cwd(), "public", "slides");
const slidesDir = existsSync(hostingSlides) ? hostingSlides : publicSlides;
const items = await readdir(slidesDir, { withFileTypes: true });
slides = items
  .filter(item => item.isDirectory())
  .map(item => item.name)
  .sort();
---

<Layout>
  <SlideList client:load slides={slides} />
</Layout>
