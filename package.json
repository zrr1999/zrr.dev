{
  "name": "zrr-website",
  "version": "0.1.0",
  "license": "GPL-3.0",
  "author": "Zhan Rongrui",
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel --filter './apps/*' run dev",
    "build": "pnpm -r --filter './apps/*' run build",
    "preview": "pnpm -r --parallel --filter './apps/*' run preview",
    "format": "pnpm -r --filter './apps/*' run format",
    "format:check": "pnpm -r --filter './apps/*' run format:check",
    "lint": "pnpm -r --filter './apps/*' run lint",
    "lint:check": "pnpm -r --filter './apps/*' run lint:check",
    "build:cf:root": "pnpm --filter @zrr-website/root run build",
    "build:cf:blog": "pnpm --filter @zrr-website/blog run build",
    "build:cf:slides": "pnpm --filter @zrr-website/slides run build",
    "deploy:cf:root": "pnpx wrangler deploy --cwd apps/root",
    "deploy:cf:blog": "pnpx wrangler deploy --cwd apps/blog",
    "deploy:cf:slides": "pnpx wrangler deploy --cwd apps/slides",
    "prepare": "pnpx prek install"
  },
  "devDependencies": {
    "oxlint": "1.61.0",
    "vite-plus": "catalog:",
    "wrangler": "4.84.1"
  },
  "packageManager": "pnpm@10.33.4"
}
